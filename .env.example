# Langflow per-client VM — environment template.
# Copy to `.env` and fill in. The real `.env` is gitignored and injected per-client at
# provision time (see autoinstall-snippet.yaml). NEVER commit a real .env.

# ── Public hostname ──────────────────────────────────────────────────────────
# The client's subdomain. Caddy obtains automatic TLS for this. DNS A/AAAA must
# point at this VM and ports 80/443 must be reachable for the cert to issue.
DOMAIN=

# ── avots.ai backend (each client uses their OWN key) ────────────────────────
# Key format: av_mcp_<...>. This is injected into the Langflow container env and
# surfaced as a Credential-type global variable (see the var below).
AVOTS_API_KEY=av_mcp_REPLACE_ME

# OpenAI-compatible base URL of the avots gateway. Used globally and is also the
# value to put in the OpenAI component's "OpenAI API Base" field inside a flow.
OPENAI_API_BASE=https://api.avots.ai/openai/v1

# Comma-separated list of env var NAMES that Langflow imports as global variables
# (Credential type). Keep AVOTS_API_KEY here so the key appears as a global variable.
LANGFLOW_VARIABLES_TO_GET_FROM_ENVIRONMENT=AVOTS_API_KEY

# ── Auth / security ──────────────────────────────────────────────────────────
# No anonymous access: a login is required.
LANGFLOW_AUTO_LOGIN=False

# Superuser bootstrap credentials (created on first start). Use a real email-like
# username and a strong, per-VM password.
LANGFLOW_SUPERUSER=admin@REPLACE_ME
LANGFLOW_SUPERUSER_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# Encrypts stored secrets / global variables and signs JWTs. MUST be unique per VM
# and MUST stay stable for the life of the VM (rotating it makes stored secrets
# undecryptable). Generate once, e.g.:
#   openssl rand -base64 48 | tr -d '\n'
LANGFLOW_SECRET_KEY=

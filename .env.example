# Langflow VM — .env. The real .env is gitignored and created on first boot.
#
# LANGFLOW_ADMIN_PASSWORD is written by the Ubuntu autoinstall (the provisioner's
# password). It is the Langflow login: admin / <LANGFLOW_ADMIN_PASSWORD>.
# LANGFLOW_SECRET_KEY (crypto/JWT) is AUTO-GENERATED by firstboot.sh — do not set it.
#
# Langflow serves its own UI on http://<host>:7860. The LLM provider/key is configured
# INSIDE Langflow as an OpenAI-compatible provider:
#   Base URL = https://api.avots.ai/openai/v1
#   API key  = your av_mcp_... key
#   Model    = e.g. anthropic/claude-opus-4.8

LANGFLOW_ADMIN_PASSWORD=REPLACE_ME

# Langflow VM — COMPOSE-LEVEL env. Copy to .env and fill in. The real .env is
# gitignored and written by the Ubuntu autoinstall (it sets ONLY PANEL_PASSWORD;
# PANEL_DOMAIN is left blank to auto-derive). NEVER commit a real .env.
#
# firstboot.sh AUTO-GENERATES LANGFLOW_SECRET_KEY into this file on first boot — you do
# NOT set it here. The Langflow login is admin / PANEL_PASSWORD (reused; set in compose).

# === CloudHosting setup panel + TLS ===
# Panel login password. REQUIRED — the panel fails closed (PANEL_REQUIRE_AUTH=1) if empty.
# ALSO used as the Langflow superuser password (login to Langflow with admin / this).
PANEL_PASSWORD=REPLACE_ME
# Public host (TLS via Let's Encrypt). Blank => firstboot derives vps-<o3>-<o4>.cloudhosting.lv.
# Panel on :8443, Langflow UI on :443 of this host.
PANEL_DOMAIN=

# === Optional turnkey avots ===
# If set, exposed inside Langflow as the AVOTS_API_KEY global variable (+ OpenAI base
# defaults to avots). Otherwise the client adds the provider/key inside Langflow.
# AVOTS_API_KEY=av_mcp_...

# Langflow is a BUILDER: configure your LLM provider INSIDE Langflow (open it from the
# panel's "Open Langflow" button). Nothing else goes here.

# Caddy terminates TLS for ${PANEL_DOMAIN} and serves TWO surfaces on the SAME
# hostname under ONE auto Let's Encrypt cert (CONVENTION across all products):
#
#   :443  -> the Langflow builder UI/API       (langflow:7860)  <- "Open Langflow"
#   :8443 -> the branded CloudHosting AI Panel (panel:8080)     <- panel is ALWAYS :8443
#
# Langflow is a BUILDER: the client configures the provider inside Langflow's own UI
# (login: admin / PANEL_PASSWORD). The panel (:8443) is a login-gated landing that
# links into Langflow via "Open Langflow" (-> https://${PANEL_DOMAIN}, i.e. :443).
#
# PANEL_DOMAIN is injected from the environment. Needs an A-record for ${PANEL_DOMAIN}
# -> this VM and ports 80 + 443 + 8443 reachable.

{
	email admin@cloudhosting.lv
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory   # uncomment while testing
}

# --- :443 — the Langflow product UI/API ------------------------------------ #
{$PANEL_DOMAIN}:443 {
	encode zstd gzip
	reverse_proxy langflow:7860 {
		# Long timeouts: builder runs/streams can be slow.
		transport http {
			read_timeout 600s
			write_timeout 600s
		}
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	log {
		output stdout
		format console
	}
}

# --- :8443 — the branded CloudHosting AI Panel ----------------------------- #
{$PANEL_DOMAIN}:8443 {
	encode zstd gzip
	reverse_proxy panel:8080 {
		transport http {
			dial_timeout 10s
			response_header_timeout 30s
		}
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}
	request_body {
		max_size 256KB
	}
	log {
		output stdout
		format console
	}
}
